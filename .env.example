# --- Environment mode ---
# 'development' relaxes secret validation (allows weak defaults for local dev).
# 'production' rejects weak defaults at startup. Default if unset: development.
ENV=development

# --- Postgres ---
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/llm_gateway

# --- Redis (required for rate limiting, worker queue, spend pre-reservation) ---
REDIS_URL=redis://localhost:6379/0

# --- Upstream (APIMart) ---
APIMART_API_KEY=
APIMART_BASE_URL=https://api.apimart.ai/v1
APIMART_TIMEOUT_CONNECT=10
APIMART_TIMEOUT_READ=120
APIMART_TIMEOUT_WRITE=30

# --- Auth ---
# JWT_SECRET MUST be set to a strong random value (>= 32 chars) in production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# --- Initial admin (created only if no admin exists yet) ---
ADMIN_EMAIL=admin@example.com
# Leave blank in production: a one-time random password will be printed to logs.
ADMIN_PASSWORD=

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- Rate limit defaults (RPM) ---
RATE_LIMIT_LOGIN_PER_15M=10
RATE_LIMIT_REFRESH_PER_HOUR=60
RATE_LIMIT_GATEWAY_RPM=60

# --- Worker ---
WORKER_TASK_SCAN_INTERVAL_SECONDS=30
